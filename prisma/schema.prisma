generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  serial    Int         @id @default(autoincrement())
  title     String
  content   String
  tags      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  Users     notesUser[]
  usersId   Int?
}

enum Roles {
  Admin
  Viewer
  Editor
}

model User {
  id       Int         @id @default(autoincrement())
  name     String?
  email    String      @unique
  password String
  notes    notesUser[]
}

model notesUser {
  user    User @relation(fields: [userId], references: [id])
  userId  Int
  note    Note @relation(fields: [notesId], references: [serial])
  notesId Int

  role Roles

  @@id([userId, notesId])
}
